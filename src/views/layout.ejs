<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/site.css" rel="stylesheet">
    <% if (typeof pageStyles !== 'undefined' && Array.isArray(pageStyles)) { %>
      <% pageStyles.forEach((stylePath) => { %>
        <link href="<%= stylePath %>" rel="stylesheet">
      <% }) %>
    <% } %>
</head>
<body>
  <%
    const resolvedRole = typeof userRole === 'string' && userRole.trim()
      ? userRole.trim()
      : 'Bruger';
    const formattedRole = resolvedRole
      .toLowerCase()
      .split(/\s+/)
      .filter(Boolean)
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(' ');
    const isAdministratorRole = resolvedRole.toLowerCase() === 'administrator';
  %>
  <% if (typeof showMenu !== 'undefined' && showMenu) { %>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
      <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="/dashboard">
          <img src="/logo-transparent.png" alt="Logo" style="height:40px;">
        </a>
        <div class="collapse navbar-collapse">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link" href="/exercises">Øvelser</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/tests">Tests</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/articles">Artikler</a>
            </li>
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
              <li class="nav-item">
                  <a class="nav-link" href="/admin">Administration</a>
              </li>
            <% } %>
            <!-- <li class="nav-item">
              <a class="nav-link" href="#">Afleveringer</a>
            </li> -->
          </ul>
          <div class="navbar-user-meta me-2">
            <span class="role-badge <%= isAdministratorRole ? 'role-badge-admin' : 'role-badge-default' %>"><%= formattedRole %></span>
            <span class="navbar-text"><%= typeof user !== 'undefined' && user ? user : '' %></span>
          </div>
          <a href="/logout" class="btn kuffert-btn-primary ms-2">Log ud</a>
        </div>
      </div>
    </nav>
  <% } %>
  <% /* Login: centreret, dashboard: ikke centreret */ %>
  <% if (!showMenu) { %>
    <div class="container d-flex align-items-center justify-content-center min-vh-100">
      <div class="w-100" style="max-width: 420px;">
        <%- body %>
      </div>
    </div>
  <% } else { %>
    <div class="container-fluid py-4">
      <%- body %>
    </div>
  <% } %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <% if (typeof pageScripts !== 'undefined' && Array.isArray(pageScripts)) { %>
    <% pageScripts.forEach((scriptPath) => { %>
      <script src="<%= scriptPath %>"></script>
    <% }) %>
  <% } %>
</body>
</html>
