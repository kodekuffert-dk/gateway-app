<%
const adminText = {
  teamCreateTitle: 'Opret hold',
  teamDefaultTitle: 'Holdadministration',
  teamCreateDescription: 'Brug samme detailvisning til at oprette et nyt hold.',
  teamEditDescription: 'Redigér oplysninger og kursustilknytninger for det valgte hold.',
  teamEmptyDescription: 'Vælg et hold i listen for at åbne administrationen.',
  teamSubmitCreate: 'Opret',
  teamSubmitEdit: 'Gem',
  courseCreateTitle: 'Opret kursus',
  courseDefaultTitle: 'Kursusadministration',
  courseCreateDescription: 'Brug samme detailvisning til at oprette et nyt kursus.',
  courseEditDescription: 'Redigér titel og beskrivelse for det valgte kursus.',
  courseEmptyDescription: 'Vælg et kursus i listen for at åbne administrationen.',
  courseSubmitCreate: 'Opret',
  courseSubmitEdit: 'Gem',
};

function toInputDate(value) {
  if (!value) {
    return '';
  }

  const asString = String(value).trim();
  const isoPrefixMatch = asString.match(/^(\d{4}-\d{2}-\d{2})/);
  if (isoPrefixMatch) {
    return isoPrefixMatch[1];
  }

  const parsedDate = new Date(asString);
  if (Number.isNaN(parsedDate.getTime())) {
    return '';
  }

  return parsedDate.toISOString().slice(0, 10);
}

const initialTeamDetailTitle = isCreatingTeam
  ? adminText.teamCreateTitle
  : (selectedTeam ? selectedTeam.name : adminText.teamDefaultTitle);
const initialTeamDetailDescription = isCreatingTeam
  ? adminText.teamCreateDescription
  : (selectedTeam ? adminText.teamEditDescription : adminText.teamEmptyDescription);

const initialCourseDetailTitle = isCreatingCourse
  ? adminText.courseCreateTitle
  : (selectedCourse ? selectedCourse.title : adminText.courseDefaultTitle);
const initialCourseDetailDescription = isCreatingCourse
  ? adminText.courseCreateDescription
  : (selectedCourse ? adminText.courseEditDescription : adminText.courseEmptyDescription);
%>

<div
  class="admin-settings-page"
  data-initial-team-mode="<%= isCreatingTeam ? 'create' : 'edit' %>"
  data-initial-team-id="<%= selectedTeam ? selectedTeam.id : '' %>"
  data-initial-course-mode="<%= isCreatingCourse ? 'create' : 'edit' %>"
  data-initial-course-id="<%= selectedCourse ? selectedCourse.id : '' %>"
  data-initial-user-team-name="<%= selectedUserTeamName || '' %>"
  data-label-team-create-title="<%= adminText.teamCreateTitle %>"
  data-label-team-default-title="<%= adminText.teamDefaultTitle %>"
  data-label-team-create-description="<%= adminText.teamCreateDescription %>"
  data-label-team-edit-description="<%= adminText.teamEditDescription %>"
  data-label-team-empty-description="<%= adminText.teamEmptyDescription %>"
  data-label-team-submit-create="<%= adminText.teamSubmitCreate %>"
  data-label-team-submit-edit="<%= adminText.teamSubmitEdit %>"
  data-label-course-create-title="<%= adminText.courseCreateTitle %>"
  data-label-course-default-title="<%= adminText.courseDefaultTitle %>"
  data-label-course-create-description="<%= adminText.courseCreateDescription %>"
  data-label-course-edit-description="<%= adminText.courseEditDescription %>"
  data-label-course-empty-description="<%= adminText.courseEmptyDescription %>"
  data-label-course-submit-create="<%= adminText.courseSubmitCreate %>"
  data-label-course-submit-edit="<%= adminText.courseSubmitEdit %>"
>
  <div class="admin-settings-header">
    <div>
      <h1 class="admin-settings-title">Administration</h1>
    </div>
  </div>

  <% if (error) { %>
    <div class="alert alert-danger admin-settings-alert"><%= error %></div>
  <% } %>

  <% if (success) { %>
    <div class="alert alert-success admin-settings-alert"><%= success %></div>
  <% } %>

  <div class="admin-settings-shell">
    <aside class="admin-settings-sidebar">
      <div class="admin-settings-sidebar-card">
        <p class="admin-settings-sidebar-label">På denne side</p>
        <nav class="admin-settings-nav" aria-label="Administrationssektioner">
          <a href="#teams">Hold</a>
          <a href="#courses">Kurser</a>
          <a href="#users">Brugere</a>
        </nav>
      </div>
    </aside>

    <div class="admin-settings-content">
      <section class="admin-settings-section" id="teams">
        <div class="admin-settings-section-header">
          <div>
            <h2>Hold</h2>
            <p>Vælg et hold i listen for at administrere det.</p>
          </div>
        </div>

        <div class="admin-settings-master-detail">
          <div class="admin-settings-panel">
            <div class="admin-settings-panel-header admin-settings-panel-header-split">
              <div>
                <h3>Holdliste</h3>
                <p><%= teams.length %> hold i kataloget.</p>
              </div>
              <button type="button" class="btn btn-outline-primary" data-admin-action="create-team">Nyt hold</button>
            </div>

            <% if (teams.length === 0) { %>
              <p class="admin-settings-empty mb-0">Der er endnu ingen hold oprettet.</p>
            <% } else { %>
              <div class="admin-settings-entity-list" aria-label="Liste over hold">
                <% teams.forEach((team) => { %>
                  <div class="admin-settings-list-row">
                    <button
                      type="button"
                      class="admin-settings-list-item <%= selectedTeam && Number(selectedTeam.id) === Number(team.id) ? 'is-active' : '' %>"
                      data-admin-action="select-team"
                      data-team-id="<%= team.id %>"
                      data-team-name="<%= team.name %>"
                      data-team-start-date="<%= toInputDate(team.startDate) %>"
                      data-team-end-date="<%= toInputDate(team.endDate) %>"
                      data-team-course-ids="<%= JSON.stringify((team.courseIds || []).map(Number)) %>"
                      aria-pressed="<%= selectedTeam && Number(selectedTeam.id) === Number(team.id) ? 'true' : 'false' %>"
                    >
                      <div class="admin-settings-list-item-content">
                        <div class="admin-settings-list-item-header">
                          <h4><%= team.name %></h4>
                          <span class="admin-settings-list-meta"><%= (team.courseIds || []).length %> kurser</span>
                        </div>
                        <p>
                          Start: <%= toInputDate(team.startDate) || 'Ikke angivet' %>
                          <% if (team.endDate) { %>
                            · Slut: <%= toInputDate(team.endDate) %>
                          <% } %>
                        </p>
                        <% if (team.courses && team.courses.length > 0) { %>
                          <div class="admin-settings-tag-list" aria-label="Tilknyttede kurser">
                            <% team.courses.forEach((courseTitle) => { %>
                              <span class="admin-settings-tag"><%= courseTitle %></span>
                            <% }) %>
                          </div>
                        <% } %>
                      </div>
                    </button>
                    <form method="post" action="/admin/teams/delete" class="admin-settings-delete-form" onsubmit="return confirm('Vil du slette dette hold?');">
                      <input type="hidden" name="redirectTo" value="/admin">
                      <input type="hidden" name="id" value="<%= team.id %>">
                      <input type="hidden" name="selectedCourseId" value="<%= selectedCourse ? selectedCourse.id : '' %>" data-sync-selected-course>
                      <button type="submit" class="btn btn-outline-danger admin-settings-delete-button" aria-label="Slet hold <%= team.name %>" title="Slet hold">
                        <span aria-hidden="true">&#128465;</span>
                      </button>
                    </form>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>

          <div class="admin-settings-panel" id="team-detail">
            <div class="admin-settings-panel-header admin-settings-panel-header-split">
              <div>
                <h3 data-team-detail-title><%= initialTeamDetailTitle %></h3>
                <p data-team-detail-description><%= initialTeamDetailDescription %></p>
              </div>
            </div>

            <form
              method="post"
              action="<%= isCreatingTeam ? '/admin/teams/create' : '/admin/teams/update' %>"
              class="admin-settings-form"
              data-team-form
            >
                <input type="hidden" name="redirectTo" value="/admin">
                <input type="hidden" name="id" value="<%= selectedTeam ? selectedTeam.id : '' %>" data-team-id-input <%= isCreatingTeam ? 'disabled' : '' %>>
                <input type="hidden" name="selectedCourseId" value="<%= selectedCourse ? selectedCourse.id : '' %>" data-selected-course-input>

                <div class="row g-3">
                  <div class="col-lg-4">
                    <label class="form-label form-label-sm" for="team-name-detail">Navn</label>
                    <input type="text" id="team-name-detail" name="name" class="form-control" value="<%= selectedTeam ? selectedTeam.name : '' %>" data-team-name-input required>
                  </div>
                  <div class="col-md-6 col-lg-3">
                    <label class="form-label form-label-sm" for="team-start-date-detail">Startdato</label>
                    <input type="date" id="team-start-date-detail" name="startDate" class="form-control" value="<%= selectedTeam ? toInputDate(selectedTeam.startDate) : '' %>" data-team-start-date-input required>
                  </div>
                  <div class="col-md-6 col-lg-3">
                    <label class="form-label form-label-sm" for="team-end-date-detail">Slutdato</label>
                    <input type="date" id="team-end-date-detail" name="endDate" class="form-control" value="<%= selectedTeam ? toInputDate(selectedTeam.endDate) : '' %>" data-team-end-date-input>
                  </div>
                  <div class="col-lg-2 d-flex align-items-end">
                    <button type="submit" class="btn kuffert-btn-primary w-100" data-team-submit-button><%= isCreatingTeam ? adminText.teamSubmitCreate : adminText.teamSubmitEdit %></button>
                  </div>
                </div>

                <div class="admin-settings-fieldset mt-4">
                  <div>
                    <h4>Tilknyttede kurser</h4>
                    <p>Markér de kurser, som dette hold skal have adgang til.</p>
                  </div>
                  <div class="admin-settings-checkbox-list">
                    <% if (courses.length === 0) { %>
                      <p class="admin-settings-empty mb-0">Der er ingen kurser at tilknytte endnu.</p>
                    <% } %>
                    <% courses.forEach((course) => { %>
                      <label class="admin-settings-checkbox-item" for="team-course-detail-<%= course.id %>">
                        <input
                          class="form-check-input mt-0"
                          type="checkbox"
                          name="courseIds"
                          value="<%= course.id %>"
                          id="team-course-detail-<%= course.id %>"
                          data-team-course-checkbox
                          <%= ((selectedTeam && selectedTeam.courseIds) || []).map(Number).includes(Number(course.id)) ? 'checked' : '' %>
                        >
                        <span>
                          <strong><%= course.title %></strong>
                          <% if (course.description) { %>
                            <small><%= course.description %></small>
                          <% } %>
                        </span>
                      </label>
                    <% }) %>
                  </div>
                </div>
              </form>
          </div>
        </div>
      </section>

      <section class="admin-settings-section" id="courses">
        <div class="admin-settings-section-header">
          <div>
            <h2>Kurser</h2>
            <p>Vælg et kursus i listen og åbn administrationen for det valgte kursus.</p>
          </div>
        </div>

        <div class="admin-settings-master-detail">
          <div class="admin-settings-panel">
            <div class="admin-settings-panel-header admin-settings-panel-header-split">
              <div>
                <h3>Kursusliste</h3>
                <p><%= courses.length %> kurser i kataloget.</p>
              </div>
              <button type="button" class="btn btn-outline-primary" data-admin-action="create-course">Nyt kursus</button>
            </div>

            <% if (courses.length === 0) { %>
              <p class="admin-settings-empty mb-0">Der er endnu ingen kurser oprettet.</p>
            <% } else { %>
              <div class="admin-settings-entity-list" aria-label="Liste over kurser">
                <% courses.forEach((course) => { %>
                  <div class="admin-settings-list-row">
                    <button
                      type="button"
                      class="admin-settings-list-item <%= selectedCourse && Number(selectedCourse.id) === Number(course.id) ? 'is-active' : '' %>"
                      data-admin-action="select-course"
                      data-course-id="<%= course.id %>"
                      data-course-title="<%= course.title %>"
                      data-course-description="<%= course.description || '' %>"
                      aria-pressed="<%= selectedCourse && Number(selectedCourse.id) === Number(course.id) ? 'true' : 'false' %>"
                    >
                      <div class="admin-settings-list-item-content">
                        <div class="admin-settings-list-item-header">
                          <h4><%= course.title %></h4>
                        </div>
                        <p><%= course.description || 'Ingen beskrivelse endnu.' %></p>
                      </div>
                    </button>
                    <form method="post" action="/admin/courses/delete" class="admin-settings-delete-form" onsubmit="return confirm('Vil du slette dette kursus?');">
                      <input type="hidden" name="redirectTo" value="/admin">
                      <input type="hidden" name="id" value="<%= course.id %>">
                      <input type="hidden" name="selectedTeamId" value="<%= selectedTeam ? selectedTeam.id : '' %>" data-sync-selected-team>
                      <button type="submit" class="btn btn-outline-danger admin-settings-delete-button" aria-label="Slet kursus <%= course.title %>" title="Slet kursus">
                        <span aria-hidden="true">&#128465;</span>
                      </button>
                    </form>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>

          <div class="admin-settings-panel" id="course-detail">
            <div class="admin-settings-panel-header admin-settings-panel-header-split">
              <div>
                <h3 data-course-detail-title><%= initialCourseDetailTitle %></h3>
                <p data-course-detail-description><%= initialCourseDetailDescription %></p>
              </div>
            </div>

              <form method="post" action="<%= isCreatingCourse ? '/admin/courses/create' : '/admin/courses/update' %>" class="admin-settings-form" data-course-form>
                <input type="hidden" name="redirectTo" value="/admin">
                <input type="hidden" name="id" value="<%= selectedCourse ? selectedCourse.id : '' %>" data-course-id-input <%= isCreatingCourse ? 'disabled' : '' %>>
                <input type="hidden" name="selectedTeamId" value="<%= selectedTeam ? selectedTeam.id : '' %>" data-selected-team-input>

                <div class="row g-3">
                  <div class="col-lg-4">
                    <label class="form-label form-label-sm" for="course-title-detail">Titel</label>
                    <input type="text" id="course-title-detail" name="title" class="form-control" value="<%= selectedCourse ? selectedCourse.title : '' %>" data-course-title-input required>
                  </div>
                  <div class="col-lg-6">
                    <label class="form-label form-label-sm" for="course-description-detail">Beskrivelse</label>
                    <input type="text" id="course-description-detail" name="description" class="form-control" value="<%= selectedCourse ? (selectedCourse.description || '') : '' %>" data-course-description-input>
                  </div>
                  <div class="col-lg-2 d-flex align-items-end">
                    <button type="submit" class="btn kuffert-btn-primary w-100" data-course-submit-button><%= isCreatingCourse ? adminText.courseSubmitCreate : adminText.courseSubmitEdit %></button>
                  </div>
                </div>
              </form>
          </div>
        </div>
      </section>

      <%
        function teamKey(value) {
          return String(value || '').trim().toLowerCase();
        }

        function sameTeamName(a, b) {
          return teamKey(a) === teamKey(b);
        }

        function buildUserTeamEntries(teamList, whitelistEntries) {
          const entryMap = new Map();

          teamList.forEach(function(team) {
            const normalizedName = String(team.name || '').trim();
            const key = teamKey(normalizedName);
            if (!key) {
              return;
            }

            entryMap.set(key, {
              teamName: normalizedName,
              emails: [],
            });
          });

          whitelistEntries.forEach(function(entry) {
            const normalizedName = String(entry && entry.teamName || '').trim();
            const key = teamKey(normalizedName);
            if (!key) {
              return;
            }

            if (!entryMap.has(key)) {
              entryMap.set(key, {
                teamName: normalizedName,
                emails: [],
              });
            }

            const targetEntry = entryMap.get(key);
            const safeEmails = Array.isArray(entry && entry.emails) ? entry.emails : [];
            targetEntry.emails = safeEmails;
          });

          return Array.from(entryMap.values()).sort(function(a, b) {
            return a.teamName.localeCompare(b.teamName, 'da', { sensitivity: 'base' });
          });
        }

        const userTeamEntries = buildUserTeamEntries(teams, whitelist || []);
      %>

      <section class="admin-settings-section" id="users">
        <div class="admin-settings-section-header">
          <div>
            <h2>Brugere</h2>
            <p>Importer whitelist-brugere fra fil og administrér dem pr. hold.</p>
          </div>
        </div>

        <% if (whitelistError) { %>
          <div class="alert alert-warning admin-settings-alert">
            Brugerdata kunne ikke hentes: <%= whitelistError %>
          </div>
        <% } %>

        <div class="admin-settings-panel admin-settings-import-panel">
          <div class="admin-settings-panel-header admin-settings-panel-header-split">
            <div>
              <h3>Importer whitelist-fil</h3>
              <p>Første linje: Holdnavn;StartDato;SlutDato (datoer er valgfrie, format YYYY-MM-DD). Findes holdet ikke i forvejen, bliver det oprettet automatisk. Resten af linjerne skal være emailadresser.</p>
            </div>
          </div>

          <form
            method="post"
            action="/admin/users/import"
            enctype="multipart/form-data"
            class="admin-settings-form"
          >
            <div class="row g-3 align-items-end">
              <div class="col-lg-8">
                <label class="form-label form-label-sm" for="whitelist-import-file">Vælg fil</label>
                <input
                  type="file"
                  name="csvFile"
                  id="whitelist-import-file"
                  class="form-control"
                  accept=".csv,.txt"
                  required
                >
              </div>
              <div class="col-lg-4 d-flex align-items-end">
                <button type="submit" class="btn kuffert-btn-primary w-100">Importer fil</button>
              </div>
            </div>
            <p class="admin-settings-helper-text mt-3 mb-0">Eksempel linje 1: Hold A;2026-08-15;2026-12-20. Hvis datoer udelades: Hold A;;</p>
          </form>
        </div>

        <div class="admin-settings-master-detail">
          <div class="admin-settings-panel">
            <div class="admin-settings-panel-header">
              <h3>Holdoversigt</h3>
              <p>Vælg et hold for at administrere tilknyttede brugere.</p>
            </div>

            <% if (userTeamEntries.length === 0) { %>
              <p class="admin-settings-empty mb-0">Der er endnu ingen hold eller whitelistede brugere.</p>
            <% } else { %>
              <div class="admin-settings-entity-list" aria-label="Holdoversigt for brugeradministration">
                <% userTeamEntries.forEach(function(entry) {
                %>
                  <button
                    type="button"
                    class="admin-settings-list-item <%= sameTeamName(selectedUserTeamName, entry.teamName) ? 'is-active' : '' %>"
                    data-admin-action="select-user-team"
                    data-user-team-name="<%= entry.teamName %>"
                    aria-pressed="<%= sameTeamName(selectedUserTeamName, entry.teamName) ? 'true' : 'false' %>"
                  >
                    <div class="admin-settings-list-item-content">
                      <div class="admin-settings-list-item-header">
                        <h4><%= entry.teamName %></h4>
                        <span class="admin-settings-list-meta"><%= entry.emails.length %> bruger<%= entry.emails.length !== 1 ? 'e' : '' %></span>
                      </div>
                    </div>
                  </button>
                <% }); %>
              </div>
            <% } %>
          </div>

          <div class="admin-settings-panel" id="user-detail">
            <div data-user-team-panel="__empty__" <% if (selectedUserTeamName) { %>style="display:none"<% } %>>
              <div class="admin-settings-panel-header">
                <h3>Brugeradministration</h3>
                <p>Vælg et hold i listen for at se og administrere brugerne på holdet.</p>
              </div>
            </div>

            <% userTeamEntries.forEach(function(entry) {
              const isVisible = sameTeamName(selectedUserTeamName, entry.teamName);
            %>
              <div data-user-team-panel="<%= entry.teamName %>" <% if (!isVisible) { %>style="display:none"<% } %>>
                <div class="admin-settings-panel-header admin-settings-panel-header-split">
                  <div>
                    <h3><%= entry.teamName %></h3>
                    <p><%= entry.emails.length %> bruger<%= entry.emails.length !== 1 ? 'e' : '' %> på dette hold.</p>
                  </div>
                </div>

                <% if (entry.emails.length === 0) { %>
                  <p class="admin-settings-empty mb-0">Der er ingen whitelistede brugere på dette hold endnu.</p>
                <% } else { %>
                  <div class="admin-settings-user-list">
                    <% entry.emails.forEach(function(emailEntry) { %>
                      <div class="admin-settings-user-row">
                        <div class="admin-settings-user-info">
                          <span class="admin-settings-user-email"><%= emailEntry.email %></span>
                          <span class="admin-settings-user-status admin-settings-user-status--<%= (emailEntry.status || '').toLowerCase() %>">
                            <%= emailEntry.status %>
                          </span>
                        </div>
                        <form
                          method="post"
                          action="/admin/users/delete"
                          class="admin-settings-delete-form"
                          onsubmit="return confirm('Vil du slette denne bruger?');"
                        >
                          <input type="hidden" name="email" value="<%= emailEntry.email %>">
                          <input type="hidden" name="teamName" value="<%= entry.teamName %>">
                          <button
                            type="submit"
                            class="btn btn-outline-danger admin-settings-delete-button"
                            aria-label="Slet bruger <%= emailEntry.email %>"
                            title="Slet bruger"
                          >
                            <span aria-hidden="true">&#128465;</span>
                          </button>
                        </form>
                      </div>
                    <% }); %>
                  </div>
                <% } %>
              </div>
            <% }); %>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>